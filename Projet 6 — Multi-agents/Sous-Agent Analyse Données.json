          "id": "92Sw6zwXOpgHrKi8",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const raw = item.json.output[0].content[0].text;\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  try {\n    const parsed = JSON.parse(cleaned);\n    return { json: { \n      total_leads: parsed.total_leads,\n      leads_qualifies: parsed.leads_qualifies,\n      score_moyen: parsed.score_moyen,\n      meilleur_lead: parsed.meilleur_lead,\n      recommandation: parsed.recommandation\n    }};\n  } catch(e) {\n    return { json: { erreur: 'Parsing échoué', raw: raw }};\n  }\n});"
      },
