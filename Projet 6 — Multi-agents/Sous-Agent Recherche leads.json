        "responses": {
          "values": [
            {
              "content": "=Tu es un expert en qualification de leads B2B.\n\nAnalyse cette entreprise et donne un score de 0 à 100 selon ces critères :\n- A un site web → +30 points\n- A un numéro de téléphone → +20 points\n- Semble être une vraie entreprise (pas un particulier) → +25 points\n- Bonne note Google (si disponible) → +15 points\n- Adresse professionnelle → +10 points\n\nDonnées de l'entreprise :\n- Nom : {{ $json.title }}\n- Adresse : {{ $json.address }}\n- Site web : {{ $json.website }}\n- Téléphone : {{ $json.phone }}\n- Note Google : {{ $json.totalScore }}\n\nRetourne UNIQUEMENT ce JSON :\n===JSON===\n{\"score\": 85, \"raison\": \"...\", \"company\": \"...\", \"website\": \"...\", \"address\": \"...\"}\n===END==="
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
