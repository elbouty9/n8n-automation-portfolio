        "openAiApi": {
          "id": "92Sw6zwXOpgHrKi8",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const raw = item.json.output[0].content[0].text;\n  const text = raw.replace(/\\\\n/g, '\\n');\n  const match = text.match(/===JSON===([\\s\\S]*?)===END===/);\n  if (!match) return { json: { score: 0, raison: 'JSON not found', raw: text } };\n  try {\n    const parsed = JSON.parse(match[1].trim());\n    return { json: { score: parsed.score, raison: parsed.raison, company: parsed.company, website: parsed.website, address: parsed.address }};\n  } catch (e) {\n    return { json: { score: 0, raison: 'JSON parse error', raw: text } };\n  }\n});"
      },
